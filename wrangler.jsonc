{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ushi-travel-api",
  "main": "worker.js",
  "compatibility_date": "2026-07-10",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ushi-travel-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],
  "vars": {
    "ALLOWED_ORIGINS": "*"
  }
}
